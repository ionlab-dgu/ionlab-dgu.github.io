---
import InternalLayout from '../../layouts/InternalLayout.astro';
import PageHeader from '../../components/common/PageHeader.astro';
import EmptyState from '../../components/common/EmptyState.astro';
import { fetchAllEvents, calendarMeta } from '../../lib/gcal';
import { calendars } from '../../lib/config';
import { dayKey } from '../../lib/attendance';

const events = await fetchAllEvents();
const today = dayKey();

// 오늘 이후 60일치만
const horizon = new Date(Date.now() + 60 * 86_400_000).toISOString().slice(0, 10);
const upcoming = events.filter((e) => {
  const d = e.start.slice(0, 10);
  return d >= today && d <= horizon;
});

// 날짜별 그룹
const byDay = new Map<string, typeof upcoming>();
for (const e of upcoming) {
  const d = e.start.slice(0, 10);
  if (!byDay.has(d)) byDay.set(d, []);
  byDay.get(d)!.push(e);
}
const days = [...byDay.entries()];

const configured = (calendars.calendars ?? []).length;

function dayLabel(d: string): string {
  const date = new Date(`${d}T00:00:00+09:00`);
  const weekday = date.toLocaleDateString('ko-KR', { weekday: 'short', timeZone: 'Asia/Seoul' });
  return `${d} (${weekday})${d === today ? ' · 오늘' : ''}`;
}

function timeLabel(iso: string, allDay: boolean): string {
  if (allDay) return '종일';
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  return d.toLocaleTimeString('ko-KR', {
    hour: '2-digit',
    minute: '2-digit',
    timeZone: 'Asia/Seoul',
  });
}
---

<InternalLayout title="캘린더">
  <PageHeader
    title="캘린더"
    description="Google Calendar가 정본입니다. 이 화면은 읽기 전용이며, 일정 추가·수정은 GCal에서 하세요."
  />

  {
    days.length === 0 ? (
      <EmptyState
        title={
          configured === 0 ? '연결된 캘린더가 없습니다' : '앞으로 60일간 등록된 일정이 없습니다'
        }
        hint={
          configured === 0
            ? 'config/calendars.yaml 의 ical_url 을 채우거나, 비공개 캘린더면 env_var 에 지정한 환경변수로 iCal 주소를 넘기세요.'
            : '캘린더는 연결되어 있지만 표시할 일정이 없습니다. GCal에 일정을 추가하면 다음 빌드부터 나타납니다.'
        }
        icon="◷"
      />
    ) : (
      <div class="space-y-8">
        {days.map(([day, dayEvents]) => (
          <section>
            <h2
              class:list={[
                'mb-2 font-mono text-sm font-semibold',
                day === today
                  ? 'text-brand-700 dark:text-brand-300'
                  : 'text-gray-500 dark:text-gray-400',
              ]}
            >
              {dayLabel(day)}
            </h2>
            <ul class="divide-y divide-gray-200 dark:divide-gray-800">
              {dayEvents.map((e) => (
                <li class="flex items-baseline gap-4 py-2.5">
                  <time class="w-16 shrink-0 font-mono text-sm text-gray-500 tabular-nums dark:text-gray-400">
                    {timeLabel(e.start, e.allDay)}
                  </time>
                  <div class="min-w-0">
                    <p>{e.summary}</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">
                      {[calendarMeta(e.calendar)?.label, e.location].filter(Boolean).join(' · ')}
                    </p>
                  </div>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )
  }

  {
    configured > 0 && (
      <section class="mt-12 border-t border-gray-200 pt-6 dark:border-gray-800">
        <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400">연결된 캘린더</h2>
        <ul class="mt-2 space-y-1 text-sm">
          {(calendars.calendars ?? []).map((c) => (
            <li class="flex flex-wrap items-baseline gap-2">
              <span>{c.label}</span>
              <span class="badge badge-neutral">{c.visibility === 'public' ? '공개' : '내부'}</span>
              {c.description && (
                <span class="text-gray-500 dark:text-gray-400">{c.description}</span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )
  }
</InternalLayout>
