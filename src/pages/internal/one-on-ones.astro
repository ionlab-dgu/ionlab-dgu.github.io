---
import InternalLayout from '../../layouts/InternalLayout.astro';
import PageHeader from '../../components/common/PageHeader.astro';
import Prose from '../../components/common/Prose.astro';
import EmptyState from '../../components/common/EmptyState.astro';
import { getOneOnOnes, displayName, getMembers } from '../../lib/content';
import { hasPrivateOverlay } from '../../lib/paths';
import { isPublicOnlyBuild } from '../../lib/auth';

/*
 * 1:1 노트는 lab-os-private 저장소에만 존재합니다.
 * .private/ 가 연결돼 있지 않거나 PUBLIC_ONLY 빌드면 여기서 아무것도 나오지 않습니다.
 *
 * ⚠️ Phase 1에는 로그인이 없어 "본인 것만" 필터를 적용할 수 없습니다.
 *    그래서 이 화면은 본문을 전부 보여주는 대신, 그 사실을 명시적으로 경고합니다.
 *    실제 접근 제한은 Phase 2의 owner 권한(config/access.yaml)에서 적용됩니다.
 */
const overlayLinked = hasPrivateOverlay();
const publicOnlyBuild = isPublicOnlyBuild();
const notes = getOneOnOnes();
const members = getMembers();

// 멤버별 그룹
const byMember = new Map<string, typeof notes>();
for (const note of notes) {
  const id = String(note.data.member ?? '알 수 없음');
  if (!byMember.has(id)) byMember.set(id, []);
  byMember.get(id)!.push(note);
}
const groups = [...byMember.entries()];
---

<InternalLayout title="1:1">
  <PageHeader
    title="1:1"
    description="PI와의 1:1 미팅 노트입니다. 본인 것과 PI만 볼 수 있어야 합니다."
  />

  {
    notes.length > 0 && (
      <div class="mb-8 rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-900 dark:border-red-700/60 dark:bg-red-900/20 dark:text-red-200">
        <p class="font-medium">주의: 지금은 본인 것만 걸러내지 못합니다</p>
        <p class="mt-1">
          로그인이 없어 누가 보고 있는지 알 수 없으므로, 이 화면은 연결된 모든 1:1 노트를 표시합니다.
          <strong>이 빌드를 다른 사람과 공유하지 마세요.</strong> 본인 것만 보이게 하는 필터는
          Phase 2에서 owner 권한과 함께 적용됩니다.
        </p>
      </div>
    )
  }

  {
    notes.length === 0 ? (
      <EmptyState
        title={
          publicOnlyBuild
            ? 'PUBLIC_ONLY 빌드에는 1:1 노트가 포함되지 않습니다'
            : overlayLinked
              ? '1:1 노트가 없습니다'
              : 'private 저장소가 연결되지 않았습니다'
        }
        hint={
          publicOnlyBuild
            ? '의도된 동작입니다. 공개 배포 빌드는 private 콘텐츠를 아예 읽지 않습니다.'
            : overlayLinked
              ? '.private/content/one-on-ones/<member-id>/YYYY-MM-DD-one_on_one.md 형식으로 추가하세요.'
              : '1:1 노트는 lab-os-private 저장소에만 있습니다. 아래 명령으로 연결하세요.'
        }
        command={!overlayLinked && !publicOnlyBuild ? 'pnpm link:private' : undefined}
        icon="🔒"
      />
    ) : (
      <div class="max-w-3xl space-y-12">
        {groups.map(([memberId, memberNotes]) => (
          <section>
            <h2 class="mb-4 border-b border-gray-200 pb-2 text-xl font-bold tracking-tight dark:border-gray-800">
              {displayName(memberId, members)}
              <span class="ml-2 text-sm font-normal text-gray-500">{memberNotes.length}건</span>
            </h2>
            <div class="space-y-8">
              {memberNotes.map((note) => (
                <article>
                  <div class="mb-2 flex items-baseline gap-3">
                    <time class="font-mono text-sm font-semibold">{note.data.date}</time>
                    <span class="badge badge-red">private</span>
                  </div>
                  <Prose body={note.body} />
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    )
  }
</InternalLayout>
