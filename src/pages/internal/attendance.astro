---
import InternalLayout from '../../layouts/InternalLayout.astro';
import PageHeader from '../../components/common/PageHeader.astro';
import PresenceWidget from '../../components/internal/PresenceWidget.astro';
import AttendanceButton from '../../components/internal/AttendanceButton.astro';
import { monthKey } from '../../lib/attendance';
import { access } from '../../lib/config';

const month = monthKey();
const principles = access.principles ?? [];
---

<InternalLayout title="출결">
  <PageHeader
    title="출결"
    description="자기 보고 방식입니다. 자동 추적하지 않고, 통계나 순위도 만들지 않습니다."
  />

  <div class="grid gap-6 lg:grid-cols-2">
    <AttendanceButton />
    <PresenceWidget />
  </div>

  <section class="mt-8">
    <h2 class="font-semibold">내 기록</h2>
    <div
      class="mt-3 rounded-xl border border-dashed border-gray-300 px-6 py-8 text-center dark:border-gray-700"
    >
      <p class="text-gray-700 dark:text-gray-300">개인 로그는 본인만 볼 수 있습니다</p>
      <p class="mx-auto mt-2 max-w-lg text-sm text-gray-500 dark:text-gray-400">
        로그인이 붙는 Phase 2부터 여기에 본인의 이번 달 기록이 표시됩니다.
        지금은 누가 로그인했는지 알 수 없으므로 아무 기록도 보여주지 않습니다.
      </p>
      <code
        class="mt-4 inline-block rounded-md bg-gray-100 px-3 py-1.5 font-mono text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-300"
      >
        data/attendance/{month}.jsonl
      </code>
    </div>
  </section>

  {
    principles.length > 0 && (
      <section class="mt-8 max-w-2xl">
        <h2 class="font-semibold">이 기능의 원칙</h2>
        <ul class="mt-3 space-y-1.5 text-sm text-gray-600 dark:text-gray-400">
          {principles.map((p) => (
            <li class="flex gap-2">
              <span class="text-gray-400">·</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
        <p class="mt-3 text-xs text-gray-500">
          config/access.yaml 에 적혀 있습니다. 기능을 추가할 때 이 원칙과 충돌하지 않는지 확인하세요.
        </p>
      </section>
    )
  }
</InternalLayout>
