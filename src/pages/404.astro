---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="페이지를 찾을 수 없습니다">
  <div class="py-16 text-center">
    <p class="text-brand-700 dark:text-brand-300 font-mono text-6xl font-bold">404</p>
    <h1 class="mt-4 text-2xl font-bold tracking-tight">페이지를 찾을 수 없습니다</h1>
    <p class="mt-3 text-gray-600 dark:text-gray-400">
      주소가 바뀌었거나, 아직 만들어지지 않은 페이지입니다.
    </p>
    <p class="mt-8">
      <a href="/" class="btn-primary inline-block">홈으로</a>
    </p>
  </div>
</PublicLayout>
