---
import PublicLayout from '../layouts/PublicLayout.astro';
import PageHeader from '../components/common/PageHeader.astro';
import { site, siteName, filled } from '../lib/config';
import { getHandbookPages, publicVisible } from '../lib/content';

const piEmail = filled(site.pi?.email);
const labEmail = filled(site.contact?.email);
const contactEmail = piEmail ?? labEmail;
const areas = site.research_areas ?? [];

const handbook = publicVisible(getHandbookPages());
const onboarding = handbook.filter((p) => p.data.section === 'onboarding');
const policies = handbook.filter((p) => p.data.section === 'policies');
---

<PublicLayout title="Join" description={`${siteName} 합류 안내`}>
  <PageHeader title="Join" description="함께 연구할 대학원생과 학부 인턴을 찾고 있습니다." />

  <div class="max-w-3xl space-y-10">
    <section>
      <h2 class="text-xl font-bold tracking-tight">Who we're looking for</h2>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        TODO: 어떤 배경·태도를 기대하는지 두세 문장으로 적어주세요. (예: 수학적 기초를 갖추고
        구현으로 검증하려는 사람, 막혔을 때 빨리 묻는 사람)
      </p>
      {
        areas.length > 0 && (
          <>
            <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">Research topics</p>
            <ul class="mt-2 flex flex-wrap gap-2">
              {areas.map((area) => (
                <li class="rounded-md bg-gray-100 px-2.5 py-1 text-sm text-gray-700 dark:bg-gray-800 dark:text-gray-300">
                  {area.title_ko ?? area.title_en}
                </li>
              ))}
            </ul>
          </>
        )
      }
    </section>

    <section>
      <h2 class="text-xl font-bold tracking-tight">How to apply</h2>
      <ol class="mt-3 list-decimal space-y-2 pl-5 text-gray-600 dark:text-gray-400">
        <li>
          아래 이메일로 연락합니다. 제목에 <strong>[지원]</strong>과 희망 과정(학부 인턴 / 석사 /
          박사)을 적어주세요.
        </li>
        <li>이력서(CV)와 성적증명서를 첨부합니다.</li>
        <li>
          관심 있는 연구 주제와 그 이유를 한 문단으로 적어주세요.
          <span class="text-gray-500">— 형식적인 자기소개보다 이 부분을 더 봅니다.</span>
        </li>
        <li>TODO: 이후 절차 (면담 → 랩 방문 → 결정 등)를 적어주세요.</li>
      </ol>

      {
        contactEmail ? (
          <p class="mt-5">
            <a href={`mailto:${contactEmail}`} class="btn-primary inline-block">
              {contactEmail} 으로 메일 보내기
            </a>
          </p>
        ) : (
          <p class="mt-5 rounded-lg border border-dashed border-gray-300 px-4 py-3 text-sm text-gray-500 dark:border-gray-700 dark:text-gray-400">
            연락처가 아직 설정되지 않았습니다. <code>config/site.yaml</code> 의<code>pi.email</code>{' '}
            또는 <code>contact.email</code> 을 채우면 여기에 메일 버튼이 표시됩니다.
          </p>
        )
      }
    </section>

    <section>
      <h2 class="text-xl font-bold tracking-tight">Before you apply</h2>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        연구실이 어떻게 굴러가는지를 핸드북에 적어두었습니다. 기대치가 맞는지 먼저 확인하는 편이
        서로에게 좋습니다.
      </p>
      <ul class="mt-4 space-y-1.5">
        {
          onboarding.map((page) => (
            <li>
              <a href={`/handbook#${page.data.slug}`} class="link">
                {page.data.title ?? page.data.slug}
              </a>
            </li>
          ))
        }
        {
          policies.map((page) => (
            <li>
              <a href={`/handbook#${page.data.slug}`} class="link">
                {page.data.title ?? page.data.slug}
              </a>
            </li>
          ))
        }
        <li><a href="/handbook#faq" class="link">FAQ</a></li>
      </ul>
    </section>
  </div>
</PublicLayout>
