---
import PublicLayout from '../../layouts/PublicLayout.astro';
import PageHeader from '../../components/common/PageHeader.astro';
import ProjectCard from '../../components/public/ProjectCard.astro';
import EmptyState from '../../components/common/EmptyState.astro';
import { getPublicResearchProjects } from '../../lib/content';
import { site, filled } from '../../lib/config';

const projects = getPublicResearchProjects();
const areas = site.research_areas ?? [];
---

<PublicLayout title="연구" description="ION Lab의 연구 분야와 진행 중인 프로젝트">
  <PageHeader title="연구" description={filled(site.lab?.tagline_ko)} />

  {
    areas.length > 0 && (
      <section class="mb-12">
        <h2 class="mb-4 text-sm font-semibold tracking-wide text-gray-500 uppercase dark:text-gray-400">
          연구 분야
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {areas.map((area) => (
            <div class="card">
              <h3 class="font-semibold">{area.title_ko ?? area.title_en}</h3>
              {area.title_ko && area.title_en && (
                <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">{area.title_en}</p>
              )}
              {filled(area.description) && (
                <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{area.description}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )
  }

  <section>
    <h2 class="mb-4 text-sm font-semibold tracking-wide text-gray-500 uppercase dark:text-gray-400">
      프로젝트
    </h2>
    {
      projects.length === 0 ? (
        <EmptyState
          title="공개된 연구 프로젝트가 없습니다"
          hint="content/research/<slug>/index.md 를 만들면 여기에 표시됩니다. _template/ 폴더를 복사해 시작하세요."
          command="pnpm new:project"
        />
      ) : (
        <div class="grid gap-4 sm:grid-cols-2">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      )
    }
  </section>
</PublicLayout>
