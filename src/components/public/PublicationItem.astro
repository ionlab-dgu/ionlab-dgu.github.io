---
import type { Doc, Member, Publication } from '../../lib/types';
import { displayName } from '../../lib/content';
import { filled } from '../../lib/config';

interface Props {
  publication: Doc<Publication>;
  /** 이름 조회를 반복하지 않도록 목록에서 한 번 읽어 넘깁니다. */
  members?: Doc<Member>[];
}

const { publication, members } = Astro.props;
const p = publication.data;

const STATUS_LABEL: Record<string, string> = {
  under_review: '심사 중',
  accepted: '게재 확정',
  published: '게재',
};

const authors = (p.authors ?? []).map((a) => displayName(a, members));
const arxiv = filled(p.arxiv);
const arxivUrl = arxiv
  ? arxiv.startsWith('http')
    ? arxiv
    : `https://arxiv.org/abs/${arxiv}`
  : undefined;
const code = filled(p.code);
const pdf = filled(p.pdf);
---

<article class="border-b border-gray-200 py-5 last:border-0 dark:border-gray-800">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <h3 class="font-medium">{p.title ?? p.slug}</h3>
    {
      p.status && p.status !== 'published' && (
        <span class:list={['badge', p.status === 'accepted' ? 'badge-green' : 'badge-amber']}>
          {STATUS_LABEL[p.status] ?? p.status}
        </span>
      )
    }
  </div>

  {
    authors.length > 0 && (
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{authors.join(', ')}</p>
    )
  }

  <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">
    {[filled(p.venue), p.year].filter(Boolean).join(', ')}
  </p>

  {
    (arxivUrl || code || pdf) && (
      <div class="mt-2 flex flex-wrap gap-3 text-sm">
        {arxivUrl && (
          <a href={arxivUrl} class="link">
            arXiv
          </a>
        )}
        {pdf && (
          <a href={pdf} class="link">
            PDF
          </a>
        )}
        {code && (
          <a href={code} class="link">
            코드
          </a>
        )}
      </div>
    )
  }
</article>
