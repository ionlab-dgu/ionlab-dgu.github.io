---
import type { ResearchProjectBundle } from '../../lib/types';
import { displayName } from '../../lib/content';
import { filled } from '../../lib/config';

interface Props {
  project: ResearchProjectBundle;
  /** internal 뷰로 링크할지 */
  internal?: boolean;
}

const { project, internal = false } = Astro.props;
const p = project.index.data;

const STATUS_LABEL: Record<string, string> = {
  idea: '구상',
  active: '진행 중',
  writing: '집필 중',
  submitted: '심사 중',
  accepted: '게재 확정',
  paused: '중단',
  archived: '보관',
};

const STATUS_TONE: Record<string, string> = {
  idea: 'badge-neutral',
  active: 'badge-green',
  writing: 'badge-blue',
  submitted: 'badge-amber',
  accepted: 'badge-green',
  paused: 'badge-neutral',
  archived: 'badge-neutral',
};

const href = `${internal ? '/internal' : ''}/research/${p.slug}`;
const lead = p.lead ? displayName(p.lead) : undefined;
const short = filled(p.short);
const venue = filled(p.target_venue);
const tags = (p.tags ?? []).filter(Boolean).slice(0, 4);
---

<a href={href} class="card hover:border-brand-400 dark:hover:border-brand-500 block transition-colors">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <h3 class="font-semibold">{p.title ?? p.slug}</h3>
    <span class:list={['badge', STATUS_TONE[p.status] ?? 'badge-neutral']}>
      {STATUS_LABEL[p.status] ?? p.status}
    </span>
  </div>

  {short && <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{short}</p>}

  <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500 dark:text-gray-400">
    {lead && <span>주도: {lead}</span>}
    {venue && <span>목표: {venue}</span>}
    {p.start && <span>시작: {p.start}</span>}
  </div>

  {
    tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((t) => (
          <span class="rounded bg-gray-100 px-1.5 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-400">
            {t}
          </span>
        ))}
      </div>
    )
  }
</a>
