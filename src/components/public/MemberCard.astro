---
import type { Doc, Member } from '../../lib/types';
import { filled } from '../../lib/config';

interface Props {
  member: Doc<Member>;
  /** 출결 상태 배지 (internal 화면에서만 넘깁니다) */
  presenceLabel?: string;
  presenceBadge?: string;
}

const { member, presenceLabel, presenceBadge } = Astro.props;
const m = member.data;

const name = m.name_ko || m.name_en || m.id;
const photo = filled(m.photo);
const initial = (m.name_ko || m.name_en || '?').trim().charAt(0);
const interests = (m.interests ?? []).map(filled).filter(Boolean).slice(0, 3);

const ROLE_LABEL: Record<string, string> = {
  pi: 'PI',
  postdoc: '박사후연구원',
  phd: '박사과정',
  ms: '석사과정',
  ug_intern: '학부 인턴',
  alumni: '졸업생',
};
---

<a
  href={`/members/${m.id}`}
  class="card hover:border-brand-300 dark:hover:border-brand-700 flex gap-4 transition-colors"
>
  {
    photo ? (
      <img src={photo} alt={name} class="h-16 w-16 shrink-0 rounded-full object-cover" />
    ) : (
      <div class="bg-brand-100 text-brand-700 dark:bg-brand-900 dark:text-brand-300 flex h-16 w-16 shrink-0 items-center justify-center rounded-full text-xl font-semibold">
        {initial}
      </div>
    )
  }

  <div class="min-w-0">
    <div class="flex flex-wrap items-center gap-2">
      <p class="font-semibold">{name}</p>
      {presenceLabel && <span class:list={['badge', presenceBadge]}>{presenceLabel}</span>}
    </div>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      {ROLE_LABEL[m.role] ?? m.role}
      {m.name_en && m.name_ko && <span class="ml-1.5 text-gray-400">· {m.name_en}</span>}
    </p>
    {
      interests.length > 0 && (
        <p class="mt-2 truncate text-sm text-gray-600 dark:text-gray-400">{interests.join(' · ')}</p>
      )
    }
  </div>
</a>
