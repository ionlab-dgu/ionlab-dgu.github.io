---
import { nav, siteName } from '../../lib/config';

const current = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  if (href === '/') return current === '/';
  return current === href || current.startsWith(href + '/');
}
---

<header
  class="border-b border-gray-200 bg-white/80 backdrop-blur dark:border-gray-800 dark:bg-gray-950/80"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="text-lg font-bold tracking-tight">{siteName}</a>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm">
      {
        nav.public.map((item) => (
          <a
            href={item.href}
            class:list={[
              'transition-colors',
              isActive(item.href)
                ? 'border-brand-400 border-b-2 pb-0.5 font-medium text-gray-900 dark:text-gray-100'
                : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/internal"
        class="rounded-md border border-gray-300 px-2.5 py-1 text-xs text-gray-600 hover:border-gray-400 dark:border-gray-700 dark:text-gray-400"
      >
        Internal
      </a>
    </div>
  </nav>
</header>
