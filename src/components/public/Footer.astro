---
import { site, siteName, siteFullName, filled } from '../../lib/config';

const email = filled(site.contact?.email);
const address = filled(site.lab?.address_ko);
const university = filled(site.lab?.university_ko);
const department = filled(site.lab?.department_ko);
const github = filled(site.links?.github);
const scholar = filled(site.links?.scholar);
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto max-w-5xl px-6 py-10 text-sm text-gray-600 dark:text-gray-400">
    <div class="flex flex-wrap justify-between gap-8">
      <div>
        <p class="font-semibold text-gray-900 dark:text-gray-100">{siteName}</p>
        {siteFullName && <p class="mt-0.5">{siteFullName}</p>}
        {
          (university || department) && (
            <p class="mt-1">{[university, department].filter(Boolean).join(' · ')}</p>
          )
        }
        {address && <p class="mt-1">{address}</p>}
        {
          email && (
            <p class="mt-1">
              <a href={`mailto:${email}`} class="link">
                {email}
              </a>
            </p>
          )
        }
      </div>

      <div class="flex flex-col gap-1">
        {
          github && (
            <a href={github} class="link">
              GitHub
            </a>
          )
        }
        {
          scholar && (
            <a href={scholar} class="link">
              Google Scholar
            </a>
          )
        }
        <a href="/join" class="link">Join</a>
      </div>
    </div>

    <p class="mt-8 text-xs text-gray-500">© {year} {siteName}. All rights reserved.</p>
  </div>
</footer>
