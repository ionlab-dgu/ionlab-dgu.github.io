---
import { nav, siteName } from '../../lib/config';

const current = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
  if (href === '/internal') return current === '/internal';
  return current === href || current.startsWith(href + '/');
}
---

<header class="border-b border-gray-200 bg-gray-50 dark:border-gray-800 dark:bg-gray-900">
  <nav class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-4">
    <div class="flex items-baseline gap-2">
      <a href="/internal" class="text-lg font-bold tracking-tight">{siteName}</a>
      <span class="badge badge-blue">내부</span>
    </div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
      {
        nav.internal.map((item) => (
          <a
            href={item.href}
            class:list={[
              'transition-colors',
              isActive(item.href)
                ? 'text-brand-600 dark:text-brand-400 font-medium'
                : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a href="/" class="text-xs text-gray-500 hover:text-gray-700 dark:hover:text-gray-300">
        ← 공개 사이트
      </a>
    </div>
  </nav>
</header>
