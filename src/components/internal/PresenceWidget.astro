---
/**
 * "지금 연구실에" 위젯.
 *
 * 상태별 인원수와 멤버별 배지만 보여줍니다.
 * 누적 시간·출석률 같은 집계는 의도적으로 만들지 않습니다 (감시 방지).
 */
import { getActiveMembers } from '../../lib/content';
import { getPresence, summarizePresence, STATE_LABEL, STATE_BADGE } from '../../lib/attendance';
import EmptyState from '../common/EmptyState.astro';
import type { PresenceState } from '../../lib/types';

const members = getActiveMembers();
const memberIds = members.map((m) => m.data.id).filter(Boolean);
const presences = getPresence(memberIds);
const counts = summarizePresence(presences);

const ORDER: PresenceState[] = ['in_lab', 'remote', 'on_break', 'out'];
const nameOf = new Map(
  members.map((m) => [m.data.id, m.data.name_ko || m.data.name_en || m.data.id]),
);
---

<section class="card">
  <div class="flex items-baseline justify-between">
    <h2 class="font-semibold">지금 연구실에</h2>
    <a href="/internal/attendance" class="link text-sm">출결 →</a>
  </div>

  {
    memberIds.length === 0 ? (
      <div class="mt-4">
        <EmptyState
          title="등록된 구성원이 없습니다"
          hint="content/members/ 에 프로필을 추가하면 여기에 표시됩니다."
          command="pnpm new:member"
        />
      </div>
    ) : (
      <>
        <div class="mt-4 grid grid-cols-4 gap-2 text-center">
          {ORDER.map((state) => (
            <div class="rounded-lg bg-gray-50 py-3 dark:bg-gray-800">
              <p class="text-2xl font-semibold tabular-nums">{counts[state]}</p>
              <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">{STATE_LABEL[state]}</p>
            </div>
          ))}
        </div>

        <ul class="mt-4 flex flex-wrap gap-2">
          {presences.map((p) => (
            <li class="flex items-center gap-1.5 rounded-md border border-gray-200 px-2 py-1 text-sm dark:border-gray-800">
              <span>{nameOf.get(p.user) ?? p.user}</span>
              <span class:list={['badge', STATE_BADGE[p.state]]}>{STATE_LABEL[p.state]}</span>
            </li>
          ))}
        </ul>
      </>
    )
  }
</section>
