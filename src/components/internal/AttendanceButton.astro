---
/**
 * 개인 출결 컨트롤 — 상태에 따라 라벨이 바뀌는 큰 버튼 하나.
 *
 * Phase 1: 정적 사이트라 실제로 기록되지 않습니다 (버튼은 비활성).
 * Phase 2: 인증 후 엔드포인트로 POST 하거나 GitHub API로 JSONL에 append.
 */
import { nextAction, STATE_LABEL, STATE_BADGE } from '../../lib/attendance';
import type { PresenceState } from '../../lib/types';

interface Props {
  /** 현재 상태. 로그인 전에는 알 수 없으므로 기본 'out'. */
  state?: PresenceState;
  /** Phase 2에서 true가 되면 실제로 동작합니다. */
  enabled?: boolean;
}

const { state = 'out', enabled = false } = Astro.props;
const next = nextAction(state);
---

<div class="card">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-sm text-gray-500 dark:text-gray-400">내 상태</p>
      <p class="mt-1 flex items-center gap-2">
        <span class:list={['badge', STATE_BADGE[state]]}>{STATE_LABEL[state]}</span>
      </p>
    </div>

    <button
      type="button"
      disabled={!enabled}
      data-action={next.action}
      class="bg-brand-400 hover:bg-brand-500 rounded-xl px-8 py-4 text-lg font-semibold text-gray-950 transition-colors disabled:cursor-not-allowed disabled:bg-gray-300 disabled:text-gray-500 dark:disabled:bg-gray-700 dark:disabled:text-gray-400"
    >
      {next.label}
    </button>
  </div>

  <div class="mt-4 flex flex-wrap gap-2 text-sm">
    <button
      type="button"
      disabled={!enabled}
      data-action="break_out"
      class="rounded-lg border border-gray-300 px-3 py-1.5 disabled:opacity-50 dark:border-gray-700"
    >
      외출
    </button>
    <button
      type="button"
      disabled={!enabled}
      data-action="remote"
      class="rounded-lg border border-gray-300 px-3 py-1.5 disabled:opacity-50 dark:border-gray-700"
    >
      재택
    </button>
  </div>

  {
    !enabled && (
      <p class="mt-4 text-xs text-gray-500 dark:text-gray-400">
        로그인 연동(Phase 2) 전까지는 버튼이 동작하지 않습니다. 기록이 필요하면
        <code class="rounded bg-gray-100 px-1 dark:bg-gray-800">data/attendance/YYYY-MM.jsonl</code>
        에 직접 한 줄 추가하세요.
      </p>
    )
  }
</div>
