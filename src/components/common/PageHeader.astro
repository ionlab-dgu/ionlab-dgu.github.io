---
interface Props {
  title: string;
  description?: string;
  /** 상단 breadcrumb 등에 쓸 작은 라벨 */
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<div class="mb-10">
  {eyebrow && <p class="text-brand-600 dark:text-brand-400 text-sm font-medium">{eyebrow}</p>}
  <div class="flex flex-wrap items-baseline justify-between gap-4">
    <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
    <slot name="actions" />
  </div>
  {description && <p class="mt-3 max-w-2xl text-gray-600 dark:text-gray-400">{description}</p>}
</div>
