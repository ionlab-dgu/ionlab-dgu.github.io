---
/**
 * 콘텐츠가 없을 때의 안내.
 *
 * 이 프로젝트의 원칙: 모든 페이지는 데이터가 하나도 없어도 정상 렌더되어야 하고,
 * 빈 화면 대신 "무엇을 하면 채워지는가"를 알려줘야 합니다.
 */
interface Props {
  title: string;
  /** 어떻게 채우는지. 파일 경로나 명령을 알려주면 좋습니다. */
  hint?: string;
  /** 실행할 명령 (pnpm new:project 등) */
  command?: string;
  icon?: string;
}

const { title, hint, command, icon = '○' } = Astro.props;
---

<div
  class="rounded-xl border border-dashed border-gray-300 px-6 py-12 text-center dark:border-gray-700"
>
  <p class="text-2xl text-gray-300 dark:text-gray-600">{icon}</p>
  <p class="mt-3 font-medium text-gray-700 dark:text-gray-300">{title}</p>
  {hint && <p class="mx-auto mt-2 max-w-md text-sm text-gray-500 dark:text-gray-400">{hint}</p>}
  {
    command && (
      <code class="mt-4 inline-block rounded-md bg-gray-100 px-3 py-1.5 font-mono text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-300">
        {command}
      </code>
    )
  }
  <slot />
</div>
