---
/**
 * 마크다운 본문을 렌더합니다.
 *
 * 스타일(.prose-lab)은 src/styles/global.css 에 있습니다.
 * Tailwind v4에서는 컴포넌트의 <style> 블록에서 @apply를 쓰려면 @reference 지시자가
 * 필요한데, 전역에 한 번만 정의하는 편이 단순해서 그렇게 했습니다.
 */
import { renderMarkdown } from '../../lib/markdown';

interface Props {
  body?: string;
  html?: string;
}

const { body, html } = Astro.props;
const rendered = html ?? renderMarkdown(body);
---

{rendered && <div class="prose-lab" set:html={rendered} />}
