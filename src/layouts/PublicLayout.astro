---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/public/Nav.astro';
import Footer from '../components/public/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** 본문 최대 폭. 목록 페이지는 wide, 글은 prose. */
  width?: 'default' | 'wide';
}

const { title, description, width = 'default' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main
    class:list={['mx-auto w-full flex-1 px-6 py-12', width === 'wide' ? 'max-w-6xl' : 'max-w-5xl']}
  >
    <slot />
  </main>
  <Footer />
</BaseLayout>
