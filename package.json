{
  "name": "lab-os",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "ION Lab (Dongguk University) lab operating system — public site and internal tooling",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.34.5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:public": "PUBLIC_ONLY=1 astro build",
    "verify:public": "node scripts/verify-public-build.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "link:private": "node scripts/link-private.mjs",
    "new:member": "node scripts/new-member.mjs",
    "new:project": "node scripts/new-project.mjs",
    "new:grant": "node scripts/new-grant.mjs",
    "new:publication": "node scripts/new-publication.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^7.1.3",
    "marked": "^18.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.3"
  }
}
